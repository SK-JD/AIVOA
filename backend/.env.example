# ─────────────────────────────────────────────────────────────
# AI-First CRM — backend environment
# Copy to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection (sync psycopg2 driver)
DATABASE_URL=postgresql+psycopg2://crm_user:crm_pass@localhost:5432/aivao_crm

# Groq LLM — bootstrap default. The Admin panel (/admin) can override
# the key and model at runtime and persist them to the database.
GROQ_API_KEY=
GROQ_MODEL=gemma2-9b-it

# Token required to call the admin settings endpoints (sent as X-Admin-Token header).
ADMIN_TOKEN=change-me-admin-token

# CORS — the frontend dev server origin
FRONTEND_ORIGIN=http://localhost:5173
